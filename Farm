local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- AUTO QUEST
local function getQuestNPC()
	for _,v in pairs(workspace:GetDescendants()) do
		if v:IsA("Model")
		and v:FindFirstChild("Head")
		and v.Name:lower():find("quest") then
			return v
		end
	end
end

local function autoQuest()
	local npc = getQuestNPC()
	if not npc then return end
	
	local char = player.Character
	if not char or not char:FindFirstChild("HumanoidRootPart") then return end
	
	local root = char.HumanoidRootPart
	
	-- dịch tới NPC
	root.CFrame = npc.Head.CFrame * CFrame.new(0,0,3)
	
	task.wait(0.5)
	
	-- gọi remote nhận quest
	pcall(function()
		game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("StartQuest", npc.Name, 1)
	end)
end

-- LOOP
task.spawn(function()
	while true do
		task.wait(3)
		autoQuest()
	end
end)
