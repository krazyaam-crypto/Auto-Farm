-- CACHE NPC
local cached = {}

task.spawn(function()
	while true do
		task.wait(1)
		cached = {}
		
		for _,v in pairs(workspace:GetChildren()) do
			if v:IsA("Model")
			and v:FindFirstChild("Humanoid")
			and v:FindFirstChild("HumanoidRootPart")
			and v.Humanoid.Health > 0
			and not Players:GetPlayerFromCharacter(v) then
				
				table.insert(cached, v)
			end
		end
	end
end)

-- NEAREST
local function getTarget(char)
	local near,dist=nil,math.huge
	
	for _,v in pairs(cached) do
		if v and v:FindFirstChild("HumanoidRootPart") then
			local d=(char.HumanoidRootPart.Position - v.HumanoidRootPart.Position).Magnitude
			if d<dist then
				dist=d
				near=v
			end
		end
	end
	
	return near
end

-- LOOP
task.spawn(function()
	local bv
	
	while true do
		task.wait(DELAY)
		
		if not FARM then 
			if bv then bv:Destroy() bv=nil end
			continue 
		end
		
		local char = player.Character
		if not char or not char:FindFirstChild("HumanoidRootPart") then continue end
		
		local root = char.HumanoidRootPart
		local target = getTarget(char)
		
		if target then
			local tRoot = target.HumanoidRootPart
			
			-- bay mượt
			if not bv then
				bv = Instance.new("BodyVelocity")
				bv.MaxForce = Vector3.new(1e9,1e9,1e9)
				bv.Parent = root
			end
			
			local pos = tRoot.Position + Vector3.new(0,HEIGHT,0)
			bv.Velocity = (pos - root.Position) * 6
			
			-- nhìn
			root.CFrame = CFrame.new(root.Position, tRoot.Position)
			
			-- hitbox
			tRoot.Size = Vector3.new(RANGE,RANGE,RANGE)
			tRoot.CanCollide = false
			
			-- magnet
			for _,v in pairs(cached) do
				if v~=target and v:FindFirstChild("HumanoidRootPart") then
					if (v.HumanoidRootPart.Position - tRoot.Position).Magnitude < MAGNET then
						v.HumanoidRootPart.CFrame = tRoot.CFrame
					end
				end
			end
			
			-- đánh
			pcall(function()
				mouse1click()
			end)
		end
	end
end)

-- TOGGLE
btn.MouseButton1Click:Connect(function()
	FARM = not FARM
	btn.Text = "AUTO FARM: "..(FARM and "ON" or "OFF")
end)
