pcall(function()
	if game.CoreGui:FindFirstChild("AutoFarmUI") then
		game.CoreGui.AutoFarmUI:Destroy()
	end
end)

local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- SETTINGS
local ENABLE = false
local MAGNET_RANGE = 10
local ATTACK_DELAY = 0.05 -- nhanh hơn
local HEIGHT = 12 -- bay cao

-- GUI
local gui = Instance.new("ScreenGui", game.CoreGui)
gui.Name = "AutoFarmUI"

local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0,200,0,100)
frame.Position = UDim2.new(0.05,0,0.3,0)
frame.BackgroundColor3 = Color3.fromRGB(20,20,20)
frame.Active = true
frame.Draggable = true
Instance.new("UICorner", frame)

local btn = Instance.new("TextButton", frame)
btn.Size = UDim2.new(0.9,0,0.6,0)
btn.Position = UDim2.new(0.05,0,0.2,0)
btn.Text = "AUTO FARM: OFF"
btn.BackgroundColor3 = Color3.fromRGB(40,40,40)
btn.TextColor3 = Color3.new(1,1,1)
btn.Font = Enum.Font.GothamBold
Instance.new("UICorner", btn)

-- Tìm NPC gần nhất
local function getNearestNPC(char)
	local nearest, dist = nil, math.huge
	
	for _,v in pairs(workspace:GetDescendants()) do
		if v:IsA("Model")
		and v:FindFirstChild("Humanoid")
		and v:FindFirstChild("HumanoidRootPart")
		and v.Humanoid.Health > 0
		and not Players:GetPlayerFromCharacter(v) then
			
			local d = (char.HumanoidRootPart.Position - v.HumanoidRootPart.Position).Magnitude
			if d < dist then
				dist = d
				nearest = v
			end
		end
	end
	
	return nearest
end

-- LOOP FARM (ổn định)
task.spawn(function()
	while true do
		task.wait(ATTACK_DELAY)
		
		if not ENABLE then continue end
		
		local char = player.Character
		if not char or not char:FindFirstChild("HumanoidRootPart") then continue end
		
		local root = char.HumanoidRootPart
		local target = getNearestNPC(char)
		
		if target and target:FindFirstChild("HumanoidRootPart") then
			local tRoot = target.HumanoidRootPart
			
			-- 🕊️ bay trên đầu
			root.CFrame = tRoot.CFrame * CFrame.new(0, HEIGHT, 0)
			
			-- 🧲 gom quái
			for _,v in pairs(workspace:GetDescendants()) do
				if v:IsA("Model")
				and v ~= target
				and v:FindFirstChild("HumanoidRootPart")
				and v:FindFirstChild("Humanoid")
				and v.Humanoid.Health > 0
				and not Players:GetPlayerFromCharacter(v) then
					
					if (v.HumanoidRootPart.Position - tRoot.Position).Magnitude < MAGNET_RANGE then
						v.HumanoidRootPart.CFrame = tRoot.CFrame * CFrame.new(math.random(-3,3),0,math.random(-3,3))
					end
				end
			end
			
			-- 🎯 nhìn vào quái
			root.CFrame = CFrame.new(root.Position, tRoot.Position)
			
			-- 📏 mở rộng hitbox (đánh xa hơn)
			tRoot.Size = Vector3.new(20,20,20)
			tRoot.Transparency = 0.5
			tRoot.CanCollide = false
			
			-- ⚡ đánh nhanh
			pcall(function()
				mouse1click()
			end)
		end
	end
end)

-- BUTTON
btn.MouseButton1Click:Connect(function()
	ENABLE = not ENABLE
	btn.Text = "AUTO FARM: "..(ENABLE and "ON" or "OFF")
end)
