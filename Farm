local Window = Rayfield:CreateWindow({
	Name = "Trung Kien Hub",
	LoadingTitle = "Loading...",
	LoadingSubtitle = "by Kien",
	ConfigurationSaving = {
		Enabled = false
	}
})

local Tab = Window:CreateTab("Farm", 4483362458)

-- SERVICES
local Players = game:GetService("Players")
local VirtualUser = game:GetService("VirtualUser")

local player = Players.LocalPlayer

-- SETTINGS
local FARM = false
local HEIGHT = 6
local DELAY = 0.03

-- GET NPC
local function getNPC(char)
	local nearest, dist = nil, math.huge
	
	for _,v in pairs(workspace:GetDescendants()) do
		if v:IsA("Model")
		and v:FindFirstChild("Humanoid")
		and v:FindFirstChild("HumanoidRootPart")
		and v.Humanoid.Health > 0
		and not Players:GetPlayerFromCharacter(v) then
			
			local d = (char.HumanoidRootPart.Position - v.HumanoidRootPart.Position).Magnitude
			
			if d < dist then
				dist = d
				nearest = v
			end
		end
	end
	
	return nearest
end

-- ATTACK (game input thật)
local function attack()
	VirtualUser:Button1Down(Vector2.new(0,0),workspace.CurrentCamera.CFrame)
	task.wait()
	VirtualUser:Button1Up(Vector2.new(0,0),workspace.CurrentCamera.CFrame)
end

-- LOOP
task.spawn(function()
	local bv
	
	while true do
		task.wait(DELAY)
		
		if not FARM then
			if bv then bv:Destroy() bv=nil end
			continue
		end
		
		local char = player.Character
		if not char or not char:FindFirstChild("HumanoidRootPart") then continue end
		
		local root = char.HumanoidRootPart
		local npc = getNPC(char)
		
		if npc then
			local tRoot = npc.HumanoidRootPart
			
			-- BAY MƯỢT (không rớt)
			if not bv then
				bv = Instance.new("BodyVelocity")
				bv.MaxForce = Vector3.new(1e9,1e9,1e9)
				bv.Parent = root
			end
			
			local targetPos = tRoot.Position + Vector3.new(0, HEIGHT, 0)
			bv.Velocity = (targetPos - root.Position) * 6
			
			-- NHÌN NPC
			root.CFrame = CFrame.new(root.Position, tRoot.Position)
			
			-- HITBOX NHẸ
			tRoot.Size = Vector3.new(10,10,10)
			tRoot.CanCollide = false
			
			-- ⚡ ATTACK REAL
			attack()
		end
	end
end)

-- TOGGLE
Tab:CreateToggle({
	Name = "Auto Farm NPC",
	CurrentValue = false,
	Callback = function(Value)
		FARM = Value
	end
})
